# Solana cluster: devnet for vault/keeper, mainnet for read-only funding rate data
SOLANA_CLUSTER=devnet

# RPC (Helius supports both devnet and mainnet endpoints)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY

# For live funding rate reads, use mainnet RPC (no auth required for public reads)
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Keeper wallet (base58 private key) — devnet wallet, no real funds needed
KEEPER_PRIVATE_KEY=

# Vault (deployed to devnet)
VAULT_PROGRAM_ID=
USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# Backpack Exchange (read-only; no auth for public funding rate endpoints)
BACKPACK_API_KEY=
BACKPACK_API_SECRET=

# Pacifica (fill when access granted; reads only in simulation mode)
PACIFICA_PROGRAM_ID=

# Phoenix Perpetuals (fill when access granted; reads only in simulation mode)
PHOENIX_PROGRAM_ID=

# Strategy flags
# USE_FALLBACK_VENUES=true uses Drift + Jupiter instead of Pacifica + Phoenix
USE_FALLBACK_VENUES=false
# LIVE_TRADING=false always in devnet/simulation mode
LIVE_TRADING=false

# Logger
LOG_DB_PATH=./data/basis.db

# API
API_PORT=3001
DASHBOARD_ORIGIN=http://localhost:3000
