# Solana cluster: devnet for vault/keeper, mainnet for read-only funding rate data
SOLANA_CLUSTER=devnet

# RPC (Helius supports both devnet and mainnet endpoints)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY

# For live funding rate reads, use mainnet RPC (no auth required for public reads)
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Keeper wallet (base58 or base64 private key) — devnet wallet, no real funds needed
KEEPER_PRIVATE_KEY=

# Vault (deployed to devnet)
VAULT_PROGRAM_ID=
USDC_MINT=Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr

# ── Backpack Exchange ────────────────────────────────────────────────────────
# Public funding rate reads need no auth; auth required for positions/orders
# Keys are base64-encoded ED25519 public/private key bytes
BACKPACK_API_KEY=
BACKPACK_API_SECRET=

# ── Pacifica Perpetuals ──────────────────────────────────────────────────────
# Market data available via WebSocket only (REST market endpoints not public)
PACIFICA_API_URL=https://api.pacifica.fi/api/v1
PACIFICA_WS_URL=wss://ws.pacifica.fi/ws
# Your Solana wallet public key for reading account/position data
PACIFICA_ACCOUNT_PUBLIC_KEY=

# ── Phoenix Perpetuals (Rise SDK) ────────────────────────────────────────────
PHOENIX_API_URL=https://perp-api.phoenix.trade
# Optional access code for invite-gated features
PHOENIX_ACCESS_CODE=

# ── Strategy flags ────────────────────────────────────────────────────────────
# LIVE_TRADING=false always in devnet/simulation mode
LIVE_TRADING=false
USE_FALLBACK_VENUES=false

# ── Infra ─────────────────────────────────────────────────────────────────────
LOG_DB_PATH=./data/basis.db
API_PORT=3001
DASHBOARD_ORIGIN=http://localhost:3000
