{
  "name": "basis",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @basis/shared build && pnpm --filter @basis/keeper build && pnpm --filter web build",
    "dev": "pnpm --parallel --filter @basis/keeper dev & pnpm --filter web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist .next && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "chai": "^6.2.2",
    "dotenv": "^16.4.5",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4"
  }
}
